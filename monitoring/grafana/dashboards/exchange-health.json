{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API Requests / sec per Exchange",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (exchange) (rate(exchange_api_requests_total[5m]))",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "API Error Rate per Exchange",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (exchange) (rate(exchange_api_requests_total{status=~\"5..|error\"}[5m])) / clamp_min(sum by (exchange) (rate(exchange_api_requests_total[5m])), 0.001)",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": []
      }
    },
    {
      "title": "p95 API Latency per Exchange + Endpoint",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, exchange, endpoint) (rate(exchange_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{exchange}} / {{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "WebSocket Connected",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "exchange_websocket_connected",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "title": "WebSocket Connection Churn (5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "description": "Approximate churn: count of gauge transitions derived from the delta of the connected flag over 5m windows.",
      "targets": [
        {
          "expr": "sum by (exchange) (changes(exchange_websocket_connected[5m]))",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["trading-bot", "exchange", "#327"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "title": "Trading Bot - Exchange Health",
  "uid": "trading-bot-exchange-health"
}
