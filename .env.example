# ===========================================
# Trading Bot v4.15 - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control!

# ============ SECURITY (REQUIRED) ============
# Encryption key for API credentials stored in database
# Auto-generated on first start if missing
# IMPORTANT: If this key changes, all stored API keys become unreadable!
# ENCRYPTION_KEY=your_fernet_key_here

# JWT signing material (REQUIRED - at least ONE of the two options below).
#
# Option A — RS256 (RECOMMENDED, asymmetric key-pair):
# Tokens are signed with the private key, verified with the public key.
# Key rotation is possible without invalidating existing sessions.
# Generate:
#   openssl genpkey -algorithm RSA -out jwt_private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Paste the PEM content (including BEGIN/END lines). Multi-line values:
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
#
# Option B — HS256 (legacy, symmetric secret):
# Kept as a fallback for the 14-day rollover window. Set BOTH options during
# the migration period; server signs with RS256 and verifies either.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# JWT_SECRET_KEY=

# ============ DATABASE ============
# Local dev (no Docker): SQLite is used by default (no config needed).
# Docker Compose: PostgreSQL is used. REQUIRED — `docker compose up` will
# abort if POSTGRES_PASSWORD is not set (SEC-C2: no weak default).
#
# Generate a strong password, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=
# Optional DATABASE_URL override (leave unset to use the compose default
# which reuses POSTGRES_PASSWORD above):
# DATABASE_URL=postgresql+asyncpg://tradingbot:YOUR_SECURE_RANDOM_PASSWORD@postgres:5432/tradingbot
#
# Connection pool settings (PostgreSQL only):
# DB_POOL_SIZE=20         # Base number of persistent connections (default: 20)
# DB_MAX_OVERFLOW=30      # Extra connections allowed beyond pool_size (default: 30)
# DB_POOL_RECYCLE=1800    # Recycle connections after N seconds (default: 1800)

# ============ MONITORING ============
# Grafana admin password (used by docker-compose grafana service).
# REQUIRED for `docker compose up` (SEC-C2: no default allowed).
GF_ADMIN_PASSWORD=

# Prometheus /metrics endpoint (#327 PR-1).
# Disabled by default. When enabled, the endpoint is gated by HTTP
# Basic-Auth — both credentials MUST be set or every request returns 401.
# PROMETHEUS_ENABLED=true
# METRICS_BASIC_AUTH_USER=
# METRICS_BASIC_AUTH_PASSWORD=

# ============ HYPERLIQUID BUILDER CODE (Revenue) ============
# Earn a fee on every Hyperliquid order your bot places.
# The fee is additional to exchange fees and goes 100% to you.
# Requirements: Builder wallet must hold >= 100 USDC in perps account.
# Users must approve your builder fee once (ApproveBuilderFee action).
#
# Your wallet address (the one receiving builder fees):
# HL_BUILDER_ADDRESS=0xYourWalletAddress
#
# Fee in tenths of basis points (1-100). Examples:
#   10 = 0.01% (recommended), 50 = 0.05%, 100 = 0.1% (max for perps)
# HL_BUILDER_FEE=10

# ============ HYPERLIQUID REFERRAL (Affiliate Revenue) ============
# Earn 10% of referred users' trading fees (cap: $1B volume per user).
# Create your code at: https://app.hyperliquid.xyz/referrals
# Requires >= $10K trading volume on your account.
#
# Your referral code (shown on the referrals page).
# IMPORTANT: When set, users MUST register via your referral link before
# they can start Hyperliquid bots. This is enforced as a hard gate.
# HL_REFERRAL_CODE=YOURCODE

# ============ AFFILIATE REVENUE FETCHER ============
# Credentials are read automatically from the admin user's stored
# exchange_connections (Admin → Einstellungen → API Keys). No ENV vars
# required for normal operation.
#
# Bitunix has NO public affiliate API and is permanently unsupported.
#
# Advanced: ENV vars below override the DB-sourced credentials per
# exchange. Only useful if you want to point the fetcher at a different
# affiliate account than the admin's trading keys.
# BITGET_AFFILIATE_API_KEY=
# BITGET_AFFILIATE_API_SECRET=
# BITGET_AFFILIATE_PASSPHRASE=
# WEEX_AFFILIATE_API_KEY=
# WEEX_AFFILIATE_API_SECRET=
# WEEX_AFFILIATE_PASSPHRASE=
# HL_REFERRER_ADDRESS=0x...
# BINGX_AGENT_API_KEY=
# BINGX_AGENT_API_SECRET=
# BINGX_AGENT_SOURCE_KEY=

# ============ FRONTEND: WALLET CONNECT ============
# Required for RainbowKit wallet connection (Builder Fee approval).
# Get a free project ID at: https://cloud.reown.com
# Without this, only injected wallets (MetaMask) work (no WalletConnect QR).
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ============ PRODUCTION SETTINGS ============
# Set to "production" to enable HSTS, disable API docs, enforce strong passwords
# ENVIRONMENT=production

# Set to "true" when behind a reverse proxy (Nginx/Caddy) so rate limiting
# and audit logging use the real client IP from X-Forwarded-For headers
# BEHIND_PROXY=true

# Allowed CORS origins (comma-separated, HTTPS only in production)
# CORS_ORIGINS=https://yourdomain.com

# ============ LOGGING ============
LOG_LEVEL=INFO
