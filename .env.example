# ===========================================
# Bitget Trading Bot v2.0 - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control!

# ============ SECURITY (REQUIRED) ============
# Encryption key for API credentials stored in database
# Auto-generated on first start if missing
# IMPORTANT: If this key changes, all stored API keys become unreadable!
# ENCRYPTION_KEY=your_fernet_key_here

# JWT secret for authentication tokens
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# MUST be set in production! Default fallback is insecure.
JWT_SECRET_KEY=change-me-in-production

# ============ DATABASE ============
# Default: SQLite (no config needed)
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
# DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# ============ LOGGING ============
LOG_LEVEL=INFO
