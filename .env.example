# ===========================================
# Bitget Trading Bot - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control!

# ============ BITGET API CREDENTIALS (LIVE TRADING) ============
# For real trades with real money
# Create these keys at: Bitget → Account → API Management
# IMPORTANT: DO NOT enable withdrawal permission!
BITGET_API_KEY=your_live_api_key_here
BITGET_API_SECRET=your_live_api_secret_here
BITGET_PASSPHRASE=your_live_passphrase_here

# ============ BITGET DEMO API CREDENTIALS (DEMO TRADING) ============
# For paper trading in Bitget Demo Account
# Create these keys at: Bitget Demo Trading → Account → API Management
# These keys are ONLY used when DEMO_MODE=true
BITGET_DEMO_API_KEY=your_demo_api_key_here
BITGET_DEMO_API_SECRET=your_demo_api_secret_here
BITGET_DEMO_PASSPHRASE=your_demo_passphrase_here

# Use testnet for testing (true/false)
# NOTE: Testnet is NOT the same as Demo Trading!
BITGET_TESTNET=false

# ============ DISCORD CONFIGURATION ============
# Discord Webhook für Trade-Benachrichtigungen (EMPFOHLEN)
# Webhook erstellen: Discord → Server auswählen → Kanal (#trading-alerts) →
# Kanal-Einstellungen → Integrationen → Webhooks → Neuer Webhook → URL kopieren
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# HINWEIS: Die folgenden Felder werden aktuell NICHT verwendet
# Der Bot nutzt ausschließlich Webhooks für Discord-Benachrichtigungen
# Sie können diese Felder leer lassen oder entfernen
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ============ TRADING CONFIGURATION ============
# Maximum trades per day (recommended: 2-3)
MAX_TRADES_PER_DAY=3

# Daily loss limit in percentage (e.g., 5 = 5%)
DAILY_LOSS_LIMIT_PERCENT=5.0

# Position size per trade in percentage of portfolio
POSITION_SIZE_PERCENT=10.0

# Leverage for futures trading (recommended: 3x for balanced risk)
LEVERAGE=3

# Take profit percentage
TAKE_PROFIT_PERCENT=3.5

# Stop loss percentage
STOP_LOSS_PERCENT=2.0

# ============ ASSETS TO TRADE ============
# Comma-separated list of trading pairs
TRADING_PAIRS=BTCUSDT,ETHUSDT

# ============ STRATEGY THRESHOLDS ============
# Fear & Greed Index thresholds
FEAR_GREED_EXTREME_FEAR=25
FEAR_GREED_EXTREME_GREED=75

# Long/Short Ratio thresholds
LONG_SHORT_CROWDED_LONGS=2.0
LONG_SHORT_CROWDED_SHORTS=0.5

# Funding Rate thresholds
FUNDING_RATE_HIGH=0.0005
FUNDING_RATE_LOW=-0.0002

# Confidence thresholds
HIGH_CONFIDENCE_MIN=85
LOW_CONFIDENCE_MIN=55

# ============ TRADING MODE ============
# Demo mode for testing without real trades (true/false)
# When true, the bot simulates trades without placing real orders
DEMO_MODE=true

# ============ DASHBOARD SECURITY ============
# API key for dashboard authentication
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# When set, all endpoints require X-API-Key header
DASHBOARD_API_KEY=

# Development mode - ONLY for local development!
# When true: Authentication is disabled (logged at startup)
# When false/unset + no API_KEY: Returns 503 error
# NEVER set to true in production!
DASHBOARD_DEV_MODE=false

# Host binding (127.0.0.1 = localhost only, 0.0.0.0 = all interfaces)
# WARNING: Only use 0.0.0.0 if you have set DASHBOARD_API_KEY!
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log
