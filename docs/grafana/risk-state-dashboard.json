  "description": "Risk-state observability: exchange rejects, 2PC intent latency, and reconcile drift. Template for Issue #216 Section 2.3 — import and tweak to taste.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "5-minute rate of exchange-client rejects, stacked by exchange. Spikes here usually precede an incident.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "rejects/sec",
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 1,
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "cps"
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (exchange) (rate(risk_exchange_reject_total[5m]))",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ],
      "title": "Exchange Reject Rate (5m)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "P50 / P95 / P99 latency of RiskStateManager.apply_intent, split per leg (tp/sl/trailing).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1},
          "unit": "s"
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (leg, le) (rate(risk_intent_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{leg}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (leg, le) (rate(risk_intent_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{leg}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (leg, le) (rate(risk_intent_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{leg}}",
          "refId": "C"
        }
      ],
      "title": "Intent Duration (P50 / P95 / P99 by leg)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Cumulative drift corrections per field, since process start. A steady climb means the exchange and the DB regularly disagree — investigate the offending exchange adapter.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1},
          "unit": "short"
        }
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 9},
      "id": 3,
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (field) (increase(risk_sync_drift_total[1h]))",
          "legendFormat": "{{field}}",
          "refId": "A"
        }
      ],
      "title": "Sync Drift Count per Field (1h increase)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
